# Git User Configuration Template
# 
# Each user should create this file at: ~/.config/git/user-config
# 
# To set up:
# 1. Create the directory: mkdir -p ~/.config/git
# 2. Copy this template: cp git-user-config.template ~/.config/git/user-config
# 3. Edit ~/.config/git/user-config with your personal details

[user]
	name = Your Name
	email = your.email@example.com
	signingkey = /home/YOUR_USERNAME/.ssh/id_ed25519.pub

[gpg "ssh"]
	allowedSignersFile = /home/YOUR_USERNAME/.ssh/allowed_signers
