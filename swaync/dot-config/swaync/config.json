{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-margin-top": 20,
  "control-center-margin-bottom": 40,
  "control-center-margin-right": 20,
  "control-center-margin-left": 20,
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 20,
  "timeout-low": 10,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 500,
  "control-center-height": 600,
  "notification-window-width": 500,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 300,
  "hide-on-clear": false,
  "hide-on-touch": true,
  "scripts": {
   "history-logger": {
    "exec": "sh -c 'echo \"$(date \"+%Y-%m-%d %H:%M:%S\") | $SWAYNC_APP_NAME: $SWAYNC_SUMMARY - $SWAYNC_BODY\" >> /home/$USER/.cache/swaync_history.log'",
    "run-on": "receive"
  },
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "notifications",
    "clear-all"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    }
  }
}
