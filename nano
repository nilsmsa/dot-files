[Unit]
Description=Polkit Authentication Agent
Documentation=man:polkit(8)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
# -- UNCOMMENT ONLY ONE OF THE BELOW EXECSTART LINES --

# For Option A (KDE Agent):
# ExecStart=/usr/lib/x86_64-linux-gnu/libexec/polkit-kde-authentication-agent-1

# For Option B (MATE Agent):
ExecStart=/usr/libexec/polkit-mate-authentication-agent-1

Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
